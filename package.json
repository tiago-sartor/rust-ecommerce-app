{
    "name": "rust-ecommerce-app",
    "version": "1.0.0",
    "author": "Tiago Sartor",
    "description": "",
    "keywords": [],
    "license": "ISC",
    "main": "index.js",
    "type": "module",
    "dependencies": {
        "alpinejs": "^3.15.12",
        "@alpinejs/collapse": "^3.15.12",
        "@alpinejs/intersect": "^3.15.12",
        "@alpinejs/persist": "^3.15.12",
        "@alpinejs/resize": "^3.15.12",
        "@alpinejs/sort": "^3.15.12",
        "@alpinejs/mask": "^3.15.12"
    },
    "devDependencies": {
        "tailwindcss": "^4.3.0",
        "@tailwindcss/cli": "^4.3.0",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3"
    },
    "scripts": {
        "dev": "npm run webpack-dev && npm run tailwind-watch-frontend && npm run tailwind-watch-admin",
        "build": "npm run webpack-build && npm run tailwind-build-frontend && npm run tailwind-build-admin",
        "webpack-dev": "webpack --mode development --watch",
        "webpack-build": "webpack --mode production",
        "tailwind-watch-frontend": "npx @tailwindcss/cli -i ./npm_src/input-frontend.css -o ./public/css/frontend.css --watch",
        "tailwind-build-frontend": "npx @tailwindcss/cli -i ./npm_src/input-frontend.css -o ./public/css/frontend.css",
        "tailwind-watch-admin": "npx @tailwindcss/cli -i ./npm_src/input-admin.css -o ./public/css/admin.css --watch",
        "tailwind-build-admin": "npx @tailwindcss/cli -i ./npm_src/input-admin.css -o ./public/css/admin.css",
        "upgrade-dependencies": "npx npm-check-updates -u && npm install"
    }
}